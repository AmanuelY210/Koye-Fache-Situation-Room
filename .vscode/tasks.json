{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "📦 Install Backend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build"
    },
    {
      "label": "📦 Install Frontend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build"
    },
    {
      "label": "📦 Install Dependencies",
      "dependsOn": ["Install Backend Dependencies", "Install Frontend Dependencies"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "🏗️ Build Frontend",
      "type": "shell",
      "command": "npx react-scripts build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build"
    },
    {
      "label": "🗄️ Import Database Schema",
      "type": "shell",
      "command": "mysql -u root < \"${workspaceFolder}/backend/config/schema.sql\"",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "📤 Create cPanel Deploy Package",
      "type": "shell",
      "command": "powershell -File \"${workspaceFolder}/build-deploy.bat\"",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build",
      "dependsOn": ["Build Frontend"]
    },
    {
      "label": "▶️ Start Backend Server",
      "type": "shell",
      "command": "node server.js",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "▶️ Start Frontend Server",
      "type": "shell",
      "command": "npx react-scripts start",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "▶️ Start Both Servers",
      "dependsOn": ["Install Dependencies", "Start Backend Server", "Start Frontend Server"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
